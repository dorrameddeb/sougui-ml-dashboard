# ------------------------------------------------------------------
# SECTION 4 : CHARGEMENT DYNAMIQUE DES DONNÉES (LA PARTIE IMPORTANTE !)
# ------------------------------------------------------------------
# @st.cache_data : Met en cache les données pour ne pas les recharger
#                  à chaque fois que l'utilisateur clique sur un bouton
#                  Cela rend l'application plus rapide.
# 
# Cette fonction charge TOUS les fichiers CSV et les fusionne
# pour créer un dataset unique et enrichi.
# ------------------------------------------------------------------
@st.cache_data
def load_all_data():
    """Charge toutes les données depuis les fichiers CSV"""
    try:
        # 4.1 : CHARGEMENT DES FICHIERS CSV
        fact_vente = pd.read_csv('Fact_Vente (1).csv')
        dim_client = pd.read_csv('Dim_Client (1).csv')
        dim_date = pd.read_csv('Dim_Date (1).csv')
        dim_produits = pd.read_csv('Dim_Produits (1).csv')
        dim_canal = pd.read_csv('Dim_Canal_Distribution (1).csv')
        dim_commandes = pd.read_csv('Dim_Commandes (1).csv')
        dim_fournisseur = pd.read_csv('Dim_Fournisseur (1).csv')
        fact_achat = pd.read_csv('Fact_Achat (1).csv')
        
        # 4.2 : NETTOYAGE DES DONNÉES
        # Conversion des colonnes en nombres (au cas où)
        fact_vente['montant_ht'] = pd.to_numeric(fact_vente['montant_ht'], errors='coerce')
        fact_vente['quantite'] = pd.to_numeric(fact_vente['quantite'], errors='coerce')
        
        # Suppression des lignes avec montant HT nul ou négatif
        fact_vente = fact_vente[fact_vente['montant_ht'] > 0]
        
        # 4.3 : NORMALISATION DES NOMS DE COLONNES
        # On met tout en minuscule pour éviter les erreurs
        for df in [dim_client, dim_produits, dim_canal, dim_date, dim_commandes, dim_fournisseur]:
            df.columns = df.columns.str.lower()
        
        # 4.4 : FUSION DES TABLES (JOINTURES)
        # On ajoute les infos client (type_client, gouvernorat)
        fact_vente = fact_vente.merge(dim_client[['client_key', 'type_client', 'gouvernorat']], on='client_key', how='left')
        
        # On ajoute les infos produit (catégorie)
        fact_vente = fact_vente.merge(dim_produits[['produit_key', 'categorie']], on='produit_key', how='left')
        
        # On ajoute les infos canal (type_canal)
        fact_vente = fact_vente.merge(dim_canal[['canal_key', 'type_canal']], on='canal_key', how='left')
        
        # On ajoute le statut de la commande
        fact_vente = fact_vente.merge(dim_commandes[['commande_key', 'statut_commande']], on='commande_key', how='left')
        
        # 4.5 : TRAITEMENT DES VALEURS MANQUANTES
        # Si un client n'a pas de type, on le met par défaut en B2C
        fact_vente['type_client'] = fact_vente['type_client'].fillna('B2C')
        
        # Si le statut est manquant, on met "En cours"
        fact_vente['statut_commande'] = fact_vente['statut_commande'].fillna('En cours')
        
        # On fusionne "En attente" avec "En cours" (car peu de données)
        fact_vente['statut_commande'] = fact_vente['statut_commande'].replace('En attente', 'En cours')
        
        # 4.6 : CRÉATION D'UNE COLONNE DATE
        # On convertit date_key (ex: 20230101) en vraie date
        fact_vente['date'] = pd.to_datetime(fact_vente['date_key'].astype(str), format='%Y%m%d', errors='coerce')
        
        # 4.7 : RETOUR DES DONNÉES
        # On retourne toutes les données et un flag "data_ok" = True
        return fact_vente, dim_client, dim_date, dim_produits, dim_canal, dim_commandes, dim_fournisseur, fact_achat, True
        
    except Exception as e:
        # Si une erreur (fichiers non trouvés), on retourne False
        print(f"Erreur: {e}")
        return None, None, None, None, None, None, None, None, False

