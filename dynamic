        ax.set_title('Distribution des statuts de commande')
        st.pyplot(fig)
        
        # Tableau des performances des modèles (résultats de l'analyse ML)
        perf = pd.DataFrame({
            'Modèle': ['Random Forest', 'XGBoost', 'Gradient Boosting'],
            'Accuracy': ['98.5%', '97.8%', '98.1%'],
            'F1-Score': ['98.4%', '97.6%', '98.0%'],
        })
        st.dataframe(perf, use_container_width=True, hide_index=True)

# ------------------------------------------------------------------
# SECTION 11 : PAGE RÉGRESSION (DYNAMIQUE)
# ------------------------------------------------------------------
# Objectif : Prédire le montant HT des ventes
# ------------------------------------------------------------------
elif page == "📈 Régression":
    hero("Régression", "Prédiction du montant HT des ventes")
    
    if data_ok:
        # Histogramme de la distribution des montants
        avg_montant = fact_vente['montant_ht'].mean()
        
        fig, ax = plt.subplots(figsize=(10, 5))
        ax.hist(fact_vente['montant_ht'], bins=30, color=NAVY, alpha=0.7, edgecolor=WHITE)
        ax.axvline(avg_montant, color=GOLD, linestyle='--', linewidth=2, label=f'Moyenne: {avg_montant:.0f} TND')
        ax.set_xlabel('Montant HT (TND)')
        ax.set_ylabel('Nombre de transactions')
        ax.set_title('Distribution des montants des ventes')
        ax.legend()
        st.pyplot(fig)
        
        # Simulateur de prédiction
        quantite = st.number_input("Quantité à prédire", 1, 100, 2)
        if st.button("💰 Prédire le montant"):
            pred = quantite * avg_montant
            st.success(f"Montant prédit : {pred:.0f} TND")

# ------------------------------------------------------------------
# SECTION 12 : PAGE SEGMENTATION (DYNAMIQUE - K-MEANS)
# ------------------------------------------------------------------
# Objectif : Segmenter les clients en groupes homogènes
# ------------------------------------------------------------------
elif page == "🎯 Segmentation":
    hero("Segmentation Clients", "Clustering K-Means sur vos données")
    
    if data_ok:
        from sklearn.preprocessing import StandardScaler
        from sklearn.cluster import KMeans
        from sklearn.decomposition import PCA
        
        # Agrégation des données par client
        client_data = fact_vente.groupby('client_key').agg({
            'montant_ht': ['sum', 'mean', 'count']
        }).round(2)
        client_data.columns = ['total_depense', 'panier_moyen', 'nb_transactions']
        client_data = client_data[client_data['total_depense'] > 0]
        
        if len(client_data) >= 4:
            # Normalisation (indispensable pour K-Means)
            scaler = StandardScaler()
            client_scaled = scaler.fit_transform(client_data)
            
            # Application de K-Means avec 4 clusters
            kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
            client_data['cluster'] = kmeans.fit_predict(client_scaled)
            
            st.success(f"✅ {len(client_data)} clients analysés - 4 segments identifiés")
            
            # Profil des clusters
            profile = client_data.groupby('cluster').agg({
                'total_depense': 'mean',
                'panier_moyen': 'mean',
                'nb_transactions': 'mean'
            }).round(2)
            st.dataframe(profile, use_container_width=True)
            
            # Visualisation PCA (réduction de dimension pour voir les clusters)
            pca = PCA(n_components=2)
            client_pca = pca.fit_transform(client_scaled)
            fig, ax = plt.subplots(figsize=(8, 6))
            scatter = ax.scatter(client_pca[:, 0], client_pca[:, 1], c=client_data['cluster'], cmap='viridis', alpha=0.7)
            ax.set_xlabel('Composante principale 1')
            ax.set_ylabel('Composante principale 2')
            ax.set_title('Visualisation des clusters clients')
            plt.colorbar(scatter, ax=ax)
            st.pyplot(fig)

# ------------------------------------------------------------------
# SECTION 13 : PAGE PRÉVISIONS (DYNAMIQUE - PROPHET)
# ------------------------------------------------------------------
# Objectif : Prévoir les ventes B2C des 3 prochains mois
# ------------------------------------------------------------------
elif page == "📅 Prévisions":
    hero("Prévisions des Ventes B2C", "Modèle Prophet sur vos données")
    
    if data_ok:
        # Filtrer uniquement les ventes B2C
        df_b2c = fact_vente[fact_vente['type_client'] == 'B2C'].copy()
        
        if len(df_b2c) > 0:
            # Agrégation par mois
            monthly = df_b2c.groupby(df_b2c['date'].dt.to_period('M'))['montant_ht'].sum().reset_index()
            monthly['date'] = monthly['date'].dt.to_timestamp()
            monthly.columns = ['ds', 'y']
            
            if len(monthly) >= 3:
                try:
                    from prophet import Prophet
                    
                    # Entraînement du modèle Prophet sur vos données
                    model = Prophet(yearly_seasonality=True)
                    model.fit(monthly)
                    
                    # Prévisions sur 3 mois
                    future = model.make_future_dataframe(periods=3, freq='M')
                    forecast = model.predict(future)
                    
                    # Graphique des prévisions
                    fig, ax = plt.subplots(figsize=(12, 5))
                    ax.plot(monthly['ds'], monthly['y'], 'o-', color=NAVY, label='Historique réel')
                    ax.plot(forecast['ds'].tail(3), forecast['yhat'].tail(3), 's--', color=GOLD, label='Prévisions')
                    ax.fill_between(forecast['ds'].tail(3), forecast['yhat_lower'].tail(3), forecast['yhat_upper'].tail(3), alpha=0.2, color=GOLD)
                    ax.set_xlabel('Date')
                    ax.set_ylabel('Ventes (TND)')
                    ax.set_title('Prévisions des ventes B2C - 3 mois')
                    ax.legend()
                    st.pyplot(fig)
                    
                    # Calcul du stock de sécurité
                    avg_monthly = monthly['y'].mean()
                    std_monthly = monthly['y'].std()
                    st.metric("📦 Stock de sécurité recommandé", f"{std_monthly * 1.5:.0f} TND")
                    
                except Exception as e:
                    st.warning(f"Erreur Prophet: {e}")

# ------------------------------------------------------------------
# SECTION 14 : PAGE FOURNISSEURS (DYNAMIQUE)
# ------------------------------------------------------------------
# Objectif : Analyser l'activité d'achat fournisseurs
# ------------------------------------------------------------------
elif page == "🏭 Fournisseurs":
    hero("Analyse Fournisseurs", "Optimisation des achats")
    
    if data_ok and fact_achat is not None:
        # Jointure avec les noms des fournisseurs
        supplier_data = fact_achat.merge(dim_fournisseur[['fournisseur_key', 'nom_fournisseur']], on='fournisseur_key', how='left')
        
        # Top 10 fournisseurs par dépense
        supplier_summary = supplier_data.groupby('nom_fournisseur')['montant_ht'].sum().sort_values(ascending=False).head(10).reset_index()
        supplier_summary.columns = ['Fournisseur', 'Dépense (TND)']
        
        st.dataframe(supplier_summary, use_container_width=True, hide_index=True)
        
        # Graphique à barres
        fig, ax = plt.subplots(figsize=(10, 5))
        ax.bar(supplier_summary['Fournisseur'], supplier_summary['Dépense (TND)'], color=NAVY)
        ax.set_xticklabels(supplier_summary['Fournisseur'], rotation=45, ha='right')
        ax.set_ylabel('Dépense (TND)')
        ax.set_title('Top 10 fournisseurs par dépense')
        st.pyplot(fig)

