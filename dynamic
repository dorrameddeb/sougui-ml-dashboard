# ------------------------------------------------------------------
# SECTION 10 : PAGE CLASSIFICATION (DYNAMIQUE)
# ------------------------------------------------------------------
# Objectif : Prédire le statut des commandes (En cours / Terminée)
# ------------------------------------------------------------------
elif page == "📊 Classification":
    hero("Classification", "Prédiction du statut des commandes")
    
    if data_ok:
        # Calcul de la distribution réelle des statuts
        statut_counts = fact_vente['statut_commande'].value_counts()
        
        # Graphique circulaire des statuts
        fig, ax = plt.subplots(figsize=(5, 4))
