if page == "🏠 Accueil":
    hero("Tableau de Bord Machine Learning", "Analyse prédictive basée sur vos données")
    
    if data_ok:
        # Calcul des KPI à partir des données réelles
        ca_total = fact_vente['montant_ht'].sum()           # Chiffre d'affaires total
        nb_clients = fact_vente['client_key'].nunique()     # Nombre de clients uniques
        nb_transactions = len(fact_vente)                   # Nombre de ventes
        panier_moyen = ca_total / nb_transactions if nb_transactions > 0 else 0
        
        # Affichage des 4 cartes KPI
