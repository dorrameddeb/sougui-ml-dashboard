    hero("Synthèse des Résultats", "Vue consolidée des objectifs atteints")
    
    # Tableau récapitulatif des objectifs
    objectifs = pd.DataFrame({
        'Objectif': ['Segmenter les clients', 'Prédire la demande', 'Analyser tendances B2C',
                     'Estimer besoins approvisionnement', 'Analyser fournisseurs', 'Prédire statut commandes'],
        'Statut': ['✅', '✅', '✅', '✅', '✅', '✅'],
        'Métrique': ['4 segments identifiés', 'R² = 0.88', 'Prévisions 3 mois', 
                     'Stock sécurité calculé', 'Top 10 fournisseurs', 'Accuracy 98.5%']
    })
    st.dataframe(objectifs, use_container_width=True, hide_index=True)
    
    divider()
    
    # Recommandations stratégiques
    rec("🎯 Recommandation 1", "Programme de fidélité VIP pour les clients les plus dépensiers")
    rec("📊 Recommandation 2", "Optimiser les stocks avec les prévisions Prophet")
    rec("🏭 Recommandation 3", "Négocier avec les top 3 fournisseurs")

